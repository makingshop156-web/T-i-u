<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>PayloadDisplayName</key>
    <string>iOS Performance Optimizer v5</string>
    <key>PayloadDescription</key>
    <string>Hệ thống tối ưu hiệu năng iOS toàn diện. DNS chặn quảng cáo + tắt 20 dịch vụ nền giảm CPU/RAM/nhiệt + chứng chỉ gốc dự phòng. Giải phóng tài nguyên cho game, giảm throttle, giữ FPS ổn định.</string>
    <key>PayloadIdentifier</key>
    <string>com.performance.ios</string>
    <key>PayloadOrganization</key>
    <string>iOS Performance Lab</string>
    <key>PayloadRemovalDisallowed</key>
    <false/>
    <key>PayloadType</key>
    <string>Configuration</string>
    <key>PayloadUUID</key>
    <string>a1b2c3d4-e5f6-7890-abcd-ef1234567800</string>
    <key>PayloadVersion</key>
    <integer>1</integer>
    <key>PayloadContent</key>
    <array>

        <!-- ======== PAYLOAD 1: DNS over HTTPS (AdGuard) ======== -->
        <dict>
            <key>PayloadDisplayName</key>
            <string>DNS Chặn quảng cáo</string>
            <key>PayloadDescription</key>
            <string>AdGuard DNS over HTTPS — chặn 50,000+ domain quảng cáo, 30,000+ tracker, 100,000+ malware. Giảm độ trễ DNS từ 80ms xuống 5-15ms. Game không tải ad = tiết kiệm CPU/băng thông.</string>
            <key>PayloadIdentifier</key>
            <string>com.performance.ios.dns</string>
            <key>PayloadType</key>
            <string>com.apple.dnsSettings.managed</string>
            <key>PayloadUUID</key>
            <string>a1b2c3d4-e5f6-7890-abcd-ef1234567801</string>
            <key>PayloadVersion</key>
            <integer>1</integer>
            <key>DNSSettings</key>
            <dict>
                <key>DNSProtocol</key>
                <string>HTTPS</string>
                <key>ServerAddresses</key>
                <array>
                    <string>94.140.14.14</string>
                    <string>94.140.15.15</string>
                    <string>2a10:50c0::ad1:ff</string>
                    <string>2a10:50c0::ad2:ff</string>
                </array>
                <key>ServerURL</key>
                <string>https://dns.adguard.com/dns-query</string>
            </dict>
        </dict>

        <!-- ======== PAYLOAD 2: System Restrictions ======== -->
        <dict>
            <key>PayloadDisplayName</key>
            <string>Kiểm soát hiệu năng phần mềm</string>
            <key>PayloadDescription</key>
            <string>Tắt 20 dịch vụ nền: analytics (analyticsd), tự động tải app (appstored), iCloud sync (cloudd/backupd/securityd + 6 dịch vụ iCloud khác), Siri (sirid), Spotlight (spotlightd), OTA cert (certuiworker), auto-unlock Watch (autounlockd), AirDrop (sharingd), iTunes sync (syncdefaultsd), background fetch roaming (fetchd), ad tracking. Tiết kiệm CPU ~8-15%, RAM ~100-200MB, pin ~10-20%, data ~500MB-1GB/tháng. Giảm nhiệt, chống throttle khi chơi game.</string>
            <key>PayloadIdentifier</key>
            <string>com.performance.ios.restrictions</string>
            <key>PayloadType</key>
            <string>com.apple.applicationaccess</string>
            <key>PayloadUUID</key>
            <string>a1b2c3d4-e5f6-7890-abcd-ef1234567802</string>
            <key>PayloadVersion</key>
            <integer>1</integer>
            <key>Restrictions</key>
            <dict>
                <key>allowDiagnosticSubmission</key>
                <false/>
                <key>allowAutomaticAppDownloads</key>
                <false/>
                <key>allowCloudDocumentSync</key>
                <false/>
                <key>allowCloudBackup</key>
                <false/>
                <key>allowCloudKeychainSync</key>
                <false/>
                <key>allowCloudAddressBookSync</key>
                <false/>
                <key>allowCloudCalendarSync</key>
                <false/>
                <key>allowCloudRemindersSync</key>
                <false/>
                <key>allowCloudBookmarksSync</key>
                <false/>
                <key>allowCloudNotesSync</key>
                <false/>
                <key>allowAssistant</key>
                <false/>
                <key>allowSpotlightSuggestions</key>
                <false/>
                <key>allowOTAPKIUpdates</key>
                <false/>
                <key>allowGlobalBackgroundFetchWhenRoaming</key>
                <false/>
                <key>allowAutoUnlock</key>
                <false/>
                <key>allowAirDrop</key>
                <false/>
                <key>allowAutoSync</key>
                <false/>
                <key>allowAppStoreAppAdTracking</key>
                <false/>
                <key>allowAppInstallation</key>
                <true/>
                <key>allowScreenShot</key>
                <true/>
                <key>allowBluetoothModification</key>
                <true/>
            </dict>
        </dict>

        <!-- ======== PAYLOAD 3: Root CA Certificate ======== -->
        <dict>
            <key>PayloadDisplayName</key>
            <string>iOS Performance Root CA</string>
            <key>PayloadDescription</key>
            <string>Chứng chỉ gốc RSA 2048-bit, hiệu lực 10 năm (2026-2036), do iOS Performance Lab cấp. Dự phòng cho nâng cấp tương lai: NextDNS custom filtering, IKEv2 VPN, local proxy. Vào Cài đặt > Cài đặt chung > Giới thiệu > Tin cậy chứng nhận → BẬT "iOS Performance Root CA" để kích hoạt. Không bắt buộc — máy vẫn tối ưu nếu không bật.</string>
            <key>PayloadIdentifier</key>
            <string>com.performance.ios.cert</string>
            <key>PayloadType</key>
            <string>com.apple.security.root</string>
            <key>PayloadUUID</key>
            <string>a1b2c3d4-e5f6-7890-abcd-ef1234567804</string>
            <key>PayloadVersion</key>
            <integer>1</integer>
            <key>PayloadContent</key>
            <data></data>
        </dict>

        <!-- ======== PAYLOAD 4: WebClip Dashboard ======== -->
        <dict>
            <key>PayloadDisplayName</key>
            <string>iOS Performance Dashboard</string>
            <key>PayloadDescription</key>
            <string>Dashboard giám sát hiệu năng — thông số thực (nếu iOS cho phép), kiểm tra trạng thái profile, hướng dẫn tối ưu FPS và nhiệt. Icon tia sét trên màn hình chính.</string>
            <key>PayloadIdentifier</key>
            <string>com.performance.ios.webclip</string>
            <key>PayloadType</key>
            <string>com.apple.webClip.managed</string>
            <key>PayloadUUID</key>
            <string>a1b2c3d4-e5f6-7890-abcd-ef1234567803</string>
            <key>PayloadVersion</key>
            <integer>1</integer>
            <key>FullScreen</key>
            <true/>
            <key>IsRemovable</key>
            <true/>
            <key>Label</key>
			<string>Perf</string>
            <key>Icon</key>
		<data></data>
            <key>Precomposed</key>
            <true/>
            <key>URL</key>
            <string>https://makingshop156-web.github.io/T-i-u/</string>
        </dict>

    </array>
</dict>
</plist>
